[gd_resource type="Theme" load_steps=22 format=3]

; Three Towers — central UI theme.
; Palette tokens (dark-fantasy / medieval):
;   Ink         Color(0.07, 0.05, 0.09)   deep purple-black background
;   Parchment   Color(0.92, 0.85, 0.68)   primary text on dark
;   Gold        Color(0.95, 0.78, 0.30)   accent / headings / borders
;   Blood       Color(0.78, 0.20, 0.20)   enemy / danger
;   Sky         Color(0.42, 0.72, 0.92)   player / safe
;   Dusk        Color(0.18, 0.14, 0.22)   panel bg
;
; Font sizes: H1 56 / H2 42 / body 32 / small 24 (the theme default below is 32).
; No font slot is wired — Godot default font is used.

