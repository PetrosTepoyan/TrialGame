[node name="Body" type="Label" parent="Center/Panel/VBox/Scroll/Margin/Inner"]
autowrap_mode = 3
horizontal_alignment = 1
text = "Swap adjacent pieces to make matches of 3+.

Every match drops an emblem into your action scale.
When the scale fills (5 emblems), your hero acts —
all 5 emblems resolve together.

The enemy fills its own scale automatically
(1 emblem per second) and acts when full.

Match-4 = stronger emblem (level 2)
Match-5 = strongest emblem (level 3)

3+ same-level emblems trigger a combo bonus."
theme_override_font_sizes/font_size = 34
theme_override_colors/font_color = Color(0.20, 0.14, 0.08, 1)
theme_override_colors/font_outline_color = Color(0.92, 0.85, 0.68, 1)
