# Copy this file to fastlane/.env and fill in real values.
# fastlane/.env is gitignored.

FASTLANE_USER="tepoyanpet@gmail.com"
FASTLANE_XCODE_LIST_TIMEOUT=120
FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT=120

# App Store Connect API key auth. The key file (AuthKey_<KEY_ID>.p8) is
# tied to the individual ASC user (not the app), so the same key from
# Memorio works for Three Towers too.
APP_STORE_CONNECT_API_KEY_ID="N8ZKDQ86BY"
APP_STORE_CONNECT_API_KEY_PATH="/Users/petrostepoyan/Memorio/iOS-App/fastlane/AuthKey_N8ZKDQ86BY.p8"
APP_STORE_CONNECT_ISSUER_ID="2d6c6b36-5681-4a89-b8a6-f3cba62805b9"
