# Fastfile for Three Towers (Godot iOS export).
#
# Flow:
#   1. Godot exports the iOS Xcode project via `make export-ios` (or the
#      Godot editor). Output: ios-export/ThreeTowers.xcodeproj.
#   2. fastlane builds, signs, and uploads it to TestFlight from that path.
#
# Auth: relies on an App Store Connect API key. Set:
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_PATH  (path to AuthKey_<ID>.p8)
# Or supply FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD for legacy Apple-ID auth.

require "shellwords"

# Force UTF-8 locale so altool's binary-IPA stream doesn't blow up with
# "invalid byte sequence in US-ASCII" (https://github.com/fastlane/fastlane/issues/21535).
ENV["LC_ALL"] ||= "en_US.UTF-8"
ENV["LANG"]   ||= "en_US.UTF-8"

xcode_select(ENV["DEVELOPER_DIR"].to_s.empty? ? "/Applications/Xcode.app" : ENV["DEVELOPER_DIR"].sub(%r{/Contents/Developer$}, ""))
default_platform(:ios)

# fastlane runs from the fastlane/ directory, so resolve paths against the repo root.
REPO_ROOT = File.expand_path("..", __dir__)
XCODEPROJ_PATH = File.join(REPO_ROOT, "ios-export/ThreeTowers.xcodeproj")
SCHEME = "ThreeTowers"

platform :ios do
  private_lane :app_store_connect_key_from_env do
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]

    next nil if key_id.to_s.empty? || key_path.to_s.empty?

    options = { key_id: key_id, key_filepath: key_path }
    options[:issuer_id] = issuer_id unless issuer_id.to_s.empty?
    app_store_connect_api_key(**options)
  end

  desc "Bump build number to a YYMMDD-sequenced value above whatever's on TestFlight."
  private_lane :ensure_unique_build_number do |options|
    api_key = options[:api_key]
    today_prefix = Time.now.strftime("%d%m%y")

    latest = nil
    if api_key
      latest = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.petrostepoyan.threetowers",
        platform: "ios",
        live: false,
        initial_build_number: 0,
      ).to_s.strip
    end

    next_seq = 0
    if latest && latest.start_with?(today_prefix)
      next_seq = latest[6..-1].to_i + 1
    end
    next_build = "#{today_prefix}#{format('%04d', next_seq)}"

    increment_build_number(
      xcodeproj: XCODEPROJ_PATH,
      build_number: next_build,
      skip_info_plist: true,
    )
    UI.message("Build number set to #{next_build}")
  end

  desc "Build the Godot-exported Xcode project and upload to TestFlight."
  lane :upload_testflight do |options|
    options ||= {}
    api_key = app_store_connect_key_from_env

    unless File.exist?(XCODEPROJ_PATH)
      UI.user_error!("Xcode project not found at #{XCODEPROJ_PATH}. Run the Godot iOS export first.")
    end

    ensure_unique_build_number(api_key: api_key) if api_key

    # Manual signing with the App Store Connect API key flow: `fastlane cert`
    # and `fastlane sigh` (run separately when the keychain doesn't already
    # have an "Apple Distribution" cert and a matching profile) deposit both
    # in the keychain / Provisioning Profiles dir. Once that's done, gym
    # builds and exports without needing an Xcode developer-account login —
    # which is brittle in CI / when the macOS Xcode token expires.
    #
    # If the cert or profile is missing, run:
    #   fastlane cert --development false --platform ios --api_key_path …
    #   fastlane sigh --app_identifier com.petrostepoyan.threetowers \
    #     --development false --platform ios --api_key_path …
    # then retry this lane.
    profile_name = "com.petrostepoyan.threetowers AppStore"
    gym(
      project: XCODEPROJ_PATH,
      scheme: SCHEME,
      export_method: "app-store",
      skip_profile_detection: true,
      # TARGETED_DEVICE_FAMILY="1,2" forces universal (iPhone + iPad) since
      # Godot 4.6's targeted_device_family=3 leaves this build setting empty,
      # which makes App Store Connect reject the bundle (90102).
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=ST2UTHBX5Z CODE_SIGN_IDENTITY=\"Apple Distribution\" PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\" TARGETED_DEVICE_FAMILY=\"1,2\"",
      export_options: {
        signingStyle: "manual",
        teamID: "ST2UTHBX5Z",
        provisioningProfiles: {
          "com.petrostepoyan.threetowers" => profile_name,
        },
      },
    )

    # Changelog: prefer the lane option, fall back to fastlane/changelog.txt.
    # Edit changelog.txt before each ship to update the "What to Test" notes
    # testers see in the TestFlight app. If the file is missing/empty, we
    # upload without a changelog and skip waiting for build processing.
    changelog_path = File.join(__dir__, "changelog.txt")
    changelog = options[:changelog]
    if (changelog.nil? || changelog.to_s.strip.empty?) && File.exist?(changelog_path)
      file_text = File.read(changelog_path).strip
      changelog = file_text unless file_text.empty?
    end

    upload_options = {}
    upload_options[:api_key] = api_key if api_key
    if changelog && !changelog.to_s.strip.empty?
      upload_options[:changelog] = changelog
      # Apple only accepts the changelog once the build leaves "Processing".
      # Setting skip_waiting=false makes pilot wait (typically 3–10 min) and
      # then apply the notes; otherwise the changelog is silently dropped.
      upload_options[:skip_waiting_for_build_processing] = false
    else
      upload_options[:skip_waiting_for_build_processing] = true
    end

    upload_to_testflight(**upload_options)
  end
end
